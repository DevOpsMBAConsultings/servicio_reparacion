<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_report_wizard_form" model="ir.ui.view">
        <field name="name">repair.report.wizard.form</field>
        <field name="model">repair.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Imprimir Informe de Taller">
                <group>
                    <field name="report_date" />
                </group>
                <footer>
                    <button name="action_print" string="Imprimir" type="object" class="btn-primary" />
                    <button string="Cancelar" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_repair_report_wizard" model="ir.actions.act_window">
        <field name="name">Imprimir Informe de Taller</field>
        <field name="res_model">repair.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>