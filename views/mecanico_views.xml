<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Action: Mecánicos list (filtered hr.employees with is_mecanico) -->
        <record id="action_servicio_mecanicos" model="ir.actions.act_window">
            <field name="name">Mecánicos</field>
            <field name="res_model">hr.employee</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="domain">[('is_mecanico', '=', True)]</field>
            <field name="context">{'default_is_mecanico': True}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Agrega tu primer técnico mecánico
                </p>
                <p>Los mecánicos son los técnicos que realizan las reparaciones.</p>
            </field>
        </record>

        <!-- Kanban view for Mecánicos (reuse employee kanban with filter) -->
        <record id="view_mecanico_kanban" model="ir.ui.view">
            <field name="name">mecanico.kanban.servicio</field>
            <field name="model">hr.employee</field>
            <field name="arch" type="xml">
                <kanban class="o_hr_employee_kanban">
                    <field name="name"/>
                    <field name="job_title"/>
                    <field name="department_id"/>
                    <field name="image_128"/>
                    <templates>
                        <t t-name="card">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('hr.employee', 'image_128', record.id.raw_value)"
                                     alt="Foto"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                                <div><field name="job_title"/></div>
                                <div><field name="department_id"/></div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Inherit employee form to add is_mecanico field -->
        <record id="view_hr_employee_form_inherit_mecanico" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.mecanico</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='job_id']" position="after">
                    <field name="is_mecanico" string="Es Mecánico de Reparación"/>
                </xpath>
            </field>
        </record>

        <!-- Action: Servicios (repair product catalog) -->
        <record id="action_servicio_productos" model="ir.actions.act_window">
            <field name="name">Servicios</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'default_type': 'service'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Agrega servicios a tu catálogo de reparación
                </p>
                <p>Define los servicios y repuestos que ofreces en tu taller.</p>
            </field>
        </record>

    </data>
</odoo>