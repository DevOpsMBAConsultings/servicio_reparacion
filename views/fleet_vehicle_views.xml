<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_vehicle_form_inherit_servicio" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.servicio</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='driver_id']" position="before">
                <field name="customer_id" placeholder="Asignar al Dueño/Cliente de la Flota" />
            </xpath>
            <xpath expr="//field[@name='location']" position="after">
                <field name="vehicle_horas" />
            </xpath>
        </field>
    </record>
</odoo>