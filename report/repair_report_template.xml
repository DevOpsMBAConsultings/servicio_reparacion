<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_repair_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style>
                            .page, .page * {
                            font-family: Arial, sans-serif !important;
                            font-size: 14px !important;
                            }
                            .header-section {
                            border: 2px solid #333;
                            margin-bottom: 20px;
                            width: 100%;
                            }
                            .header-row {
                            display: table;
                            width: 100%;
                            table-layout: fixed;
                            }
                            .header-col-left {
                            display: table-cell;
                            width: 25%;
                            text-align: center;
                            padding: 10px;
                            vertical-align: middle;
                            }
                            .header-col-center {
                            display: table-cell;
                            width: 50%;
                            background-color: #2A3382;
                            color: white;
                            text-align: center;
                            padding: 20px;
                            vertical-align: middle;
                            }
                            .header-col-center h2 {
                            margin: 0;
                            color: white;
                            text-transform: uppercase;
                            font-weight: bold;
                            letter-spacing: 1px;
                            font-size: 20px !important;
                            }
                            .header-col-right {
                            display: table-cell;
                            width: 25%;
                            text-align: center;
                            padding: 10px;
                            vertical-align: middle;
                            }
                            .header-section img {
                            max-height: 173px;
                            max-width: 100%;
                            }
                            .header-col-left img {
                            max-height: 190px;
                            }
                            .section-wrapper {
                            page-break-inside: avoid;
                            orphans: 3;
                            widows: 3;
                            }
                            .section-title {
                            background-color: #2A3382;
                            color: white;
                            padding: 10px 15px;
                            margin-top: 20px;
                            margin-bottom: 0;
                            font-weight: bold;
                            text-transform: uppercase;
                            page-break-after: avoid;
                            }
                            .section-content {
                            padding: 10px 15px;
                            border: 2px solid #2A3382;
                            border-top: none;
                            page-break-inside: avoid;
                            }
                            .data-row {
                            display: table;
                            width: 100%;
                            margin-bottom: 8px;
                            }
                            .data-label {
                            display: table-cell;
                            font-weight: bold;
                            width: 130px;
                            vertical-align: top;
                            }
                            .data-value {
                            display: table-cell;
                            vertical-align: top;
                            }
                            .footer-signatures {
                            margin-top: 50px;
                            width: 100%;
                            }
                            .signature-box {
                            width: 45%;
                            display: inline-block;
                            text-align: center;
                            vertical-align: top;
                            }
                            .signature-line {
                            border-top: 2px solid black;
                            margin-top: 60px;
                            padding-top: 5px;
                            font-weight: bold;
                            }
                            .report-date {
                            margin-top: 30px;
                            text-align: right;
                            font-style: italic;
                            }
                        </style>

                        <div class="header-section">
                            <div class="header-row">
                                <div class="header-col-left">
                                    <img src="/servicio_reparacion/static/src/img/logo1.png" />
                                </div>
                                <div class="header-col-center">
                                    <h2>Informe Técnico Taller</h2>
                                </div>
                                <div class="header-col-right">
                                    <img src="/servicio_reparacion/static/src/img/logo2.png" />
                                </div>
                            </div>
                        </div>

                        <div class="row" style="margin-top: 20px;">
                            <div class="col-6" style="padding-right: 15px;">
                                <div class="section-wrapper h-100">
                                    <div class="section-title" style="margin-top: 0;">1. DATOS
                                        GENERALES:</div>
                                    <div class="section-content h-100">
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">CLIENTE:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">DIRECCIÓN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.street" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">EMAIL:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.email" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">TELÉFONO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.phone" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">TÉCNICO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.mecanico_id.name" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6" style="padding-left: 15px;">
                                <div class="section-wrapper h-100">
                                    <div class="section-title" style="margin-top: 0;">2. DATOS DEL
                                        EQUIPO:</div>
                                    <div class="section-content h-100">
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">MARCA:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.brand_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">VIN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.vin_sn" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">MODELO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.model_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">PLACA:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.license_plate" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">
                                                KM/ODÓMETRO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.odometer" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">HORAS:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_horas" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">UBICACIÓN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.location" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">3. ANTECEDENTES DEL SERVICIO:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.antecedentes_servicio" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">4. HALLAZGOS:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.hallazgos" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">5. ACCIÓN CORRECTIVA:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.accion_correctiva" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">6. RECOMENDACIONES:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.recomendaciones" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper"
                            style="page-break-inside: avoid; margin-top: 20px;">
                            <div class="section-title" style="margin-top: 0;">7. IMÁGENES:</div>
                            <div class="section-content">
                                <t t-foreach="doc.image_ids" t-as="img">
                                    <div
                                        style="float: left; width: 33%; padding: 5px; text-align: center; box-sizing: border-box; page-break-inside: avoid;">
                                        <div
                                            style="border: 2px solid #2A3382; padding: 5px; border-radius: 4px;">
                                            <img t-if="img.image"
                                                t-att-src="image_data_uri(img.image)"
                                                style="max-width: 100%; max-height: 200px; display: block; margin: 0 auto;" />
                                            <div t-if="img.description"
                                                style="margin-top: 5px; color: #666; font-style: italic;">
                                                <span t-field="img.description" />
                                            </div>
                                        </div>
                                    </div>
                                </t>
                                <div style="clear: both;"></div>
                            </div>

                            <!-- CUSTOM FOOTER: Bound to Section 7 to prevent orphaning -->
                            <div class="report-footer-container"
                                style="padding-top: 40px; width: 100%;">
                                <div class="report-date"
                                    style="text-align: right; font-style: italic;"> Fecha del
                                    Reporte: <span
                                        t-esc="res_company.env.context.get('report_date')"
                                        t-options='{"widget": "date"}' />
                                </div>


                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>