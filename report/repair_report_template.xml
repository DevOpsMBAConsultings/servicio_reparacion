<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_repair_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <style>
                            .header-section {
                            border: 2px solid #333;
                            margin-bottom: 20px;
                            width: 100%;
                            }
                            .header-row {
                            display: table;
                            width: 100%;
                            table-layout: fixed;
                            }
                            .header-col-left {
                            display: table-cell;
                            width: 25%;
                            text-align: center;
                            padding: 10px;
                            vertical-align: middle;
                            }
                            .header-col-center {
                            display: table-cell;
                            width: 50%;
                            background-color: #0052CC;
                            color: white;
                            text-align: center;
                            padding: 20px;
                            vertical-align: middle;
                            }
                            .header-col-center h2 {
                            margin: 0;
                            color: white;
                            font-size: 26px;
                            text-transform: uppercase;
                            font-weight: bold;
                            letter-spacing: 1px;
                            }
                            .header-col-right {
                            display: table-cell;
                            width: 25%;
                            text-align: center;
                            padding: 10px;
                            vertical-align: middle;
                            }
                            .header-section img {
                            max-height: 80px;
                            max-width: 100%;
                            }
                            .section-wrapper {
                            page-break-inside: avoid;
                            orphans: 3;
                            widows: 3;
                            }
                            .section-title {
                            background-color: #0052CC;
                            color: white;
                            padding: 10px 15px;
                            margin-top: 20px;
                            margin-bottom: 10px;
                            font-size: 14px;
                            font-weight: bold;
                            text-transform: uppercase;
                            page-break-after: avoid;
                            }
                            .section-content {
                            padding: 10px 15px;
                            border: 1px solid #ddd;
                            border-top: none;
                            page-break-inside: avoid;
                            }
                            .data-row {
                            display: flex;
                            margin-bottom: 8px;
                            }
                            .data-label {
                            font-weight: bold;
                            width: 150px;
                            }
                            .data-value {
                            flex: 1;
                            }
                        </style>

                        <div class="header-section">
                            <div class="header-row">
                                <div class="header-col-left">
                                    <img src="/servicio_reparacion/static/src/img/logo1.png" />
                                </div>
                                <div class="header-col-center">
                                    <h2>Informe Técnico Taller</h2>
                                </div>
                                <div class="header-col-right">
                                    <img src="/servicio_reparacion/static/src/img/logo2.png" />
                                </div>
                            </div>
                        </div>

                        <div class="row" style="margin-top: 20px;">
                            <div class="col-6">
                                <div class="section-wrapper h-100">
                                    <div class="section-title" style="margin-top: 0;">1. DATOS
                                        GENERALES:</div>
                                    <div class="section-content h-100">
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">CLIENTE:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">DIRECCIÓN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.street" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">EMAIL:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.email" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">TELÉFONO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.phone" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">TÉCNICO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.mecanico_id.name" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-1">
                                <!-- Spacer column -->
                            </div>
                            <div class="col-5">
                                <div class="section-wrapper h-100">
                                    <div class="section-title" style="margin-top: 0;">2. DATOS DEL
                                        EQUIPO:</div>
                                    <div class="section-content h-100">
                                        <div class="data-row">
                                            <div class="data-label" style="width: 80px;">MARCA:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.brand_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 80px;">VIN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.vin_sn" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 80px;">MODELO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.model_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 80px;">PLACA:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.license_plate" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">3. ANTECEDENTES DEL SERVICIO:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.antecedentes_servicio" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">4. HALLAZGOS:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.hallazgos" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">5. ACCIÓN CORRECTIVA:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.accion_correctiva" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper">
                            <div class="section-title">6. RECOMENDACIONES:</div>
                            <div class="section-content">
                                <p>
                                    <span t-field="doc.recomendaciones" />
                                </p>
                            </div>
                        </div>

                        <div class="section-wrapper" t-if="doc.image_ids">
                            <div class="section-title">7. IMÁGENES:</div>
                            <div class="section-content">
                                <div class="row">
                                    <t t-foreach="doc.image_ids" t-as="img">
                                        <div class="col-4 mb-4" style="text-align: center;">
                                            <div
                                                style="border: 1px solid #ddd; padding: 5px; border-radius: 4px;">
                                                <img t-if="img.image"
                                                    t-att-src="image_data_uri(img.image)"
                                                    style="max-width: 100%; max-height: 200px; display: block; margin: 0 auto;" />
                                                <div t-if="img.description"
                                                    style="font-size: 11px; margin-top: 5px; color: #666; font-style: italic;">
                                                    <span t-field="img.description" />
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>