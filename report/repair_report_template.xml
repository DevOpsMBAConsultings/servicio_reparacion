<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_repair_order_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style>
                            .page {
                            text-align: left !important;
                            width: 100% !important;
                            }
                            /* Forzar alineación a la izquierda en absolutamente todo dentro de
                            .page */
                            .page * {
                            text-align: left !important;
                            font-family: Arial, sans-serif !important;
                            font-size: 14px !important;
                            }
                            /* Excepciones específicas para elementos que SÍ deben estar centrados
                            */
                            .header-col-left, .header-col-center, .header-col-right,
                            .header-col-center h2, .header-section img,
                            .signature-box, .signature-line {
                            text-align: center !important;
                            }
                            .header-section {
                            border: 2px solid #2A3382;
                            margin-bottom: 20px;
                            width: 100%;
                            }
                            .header-row {
                            display: table;
                            width: 100%;
                            table-layout: fixed;
                            }
                            .header-col-left {
                            display: table-cell;
                            width: 25%;
                            text-align: center !important;
                            padding: 10px;
                            vertical-align: middle;
                            }
                            .header-col-center {
                            display: table-cell;
                            width: 50%;
                            background-color: #2A3382;
                            color: white;
                            text-align: center !important;
                            padding: 20px;
                            vertical-align: middle;
                            }
                            .header-col-center h2 {
                            margin: 0;
                            color: white;
                            text-transform: uppercase;
                            font-weight: bold;
                            letter-spacing: 1px;
                            font-size: 20px !important;
                            text-align: center !important;
                            }
                            .header-col-right {
                            display: table-cell;
                            width: 25%;
                            text-align: center !important;
                            padding: 10px;
                            vertical-align: middle;
                            }
                            .header-section img {
                            max-height: 173px;
                            max-width: 100%;
                            }
                            .header-col-left img {
                            max-height: 190px;
                            }
                            .section-table {
                            width: 100%;
                            border-collapse: collapse !important;
                            border: 2px solid #2A3382;
                            margin-top: 40px;
                            page-break-inside: auto;
                            }
                            .section-table thead {
                            display: table-header-group; /* Repeats on every page */
                            }
                            .section-table thead tr {
                            height: 0;
                            line-height: 0;
                            }
                            .section-table thead th {
                            padding: 0 !important;
                            margin: 0 !important;
                            border-top: 2px solid #2A3382 !important; /* The 'top border' that
                            repeats */
                            height: 0;
                            line-height: 0;
                            }
                            /* First page title row (Non-repeating) */
                            .section-table tbody .title-row td {
                            background-color: #2A3382;
                            color: white;
                            padding: 10px 15px !important;
                            font-weight: bold;
                            text-transform: uppercase;
                            font-size: 14px !important;
                            border: none;
                            line-height: 1.1 !important;
                            }
                            .section-table tbody td {
                            padding: 10px 15px !important;
                            vertical-align: top;
                            border: none;
                            text-align: left !important;
                            line-height: 1.1 !important; /* Very compact */
                            margin: 0 !important;
                            }
                            .section-table tbody td * {
                            margin: 0 !important;
                            padding: 0 !important;
                            line-height: 1.1 !important;
                            display: inline;
                            }
                            .section-table tfoot {
                            display: table-footer-group; /* Repeats on every page */
                            }
                            .section-table tfoot td {
                            height: 0;
                            border-top: 2px solid #2A3382 !important; /* The 'bottom border' that
                            repeats */
                            padding: 0 !important;
                            line-height: 0 !important;
                            font-size: 0 !important;
                            margin: 0 !important;
                            }
                            .section-title-box {
                            background-color: #2A3382;
                            color: white;
                            padding: 10px 15px;
                            font-weight: bold;
                            text-transform: uppercase;
                            margin: 0;
                            font-size: 14px !important;
                            line-height: 1.1 !important;
                            }
                            .data-row {
                            display: table;
                            width: 100%;
                            margin-bottom: 8px;
                            text-align: left !important;
                            }
                            .data-label {
                            display: table-cell;
                            font-weight: bold;
                            width: 130px;
                            vertical-align: top;
                            text-align: left !important;
                            }
                            .data-value {
                            display: table-cell;
                            vertical-align: top;
                            text-align: left !important;
                            }
                            .footer-signatures {
                            margin-top: 50px;
                            width: 100%;
                            }
                            .signature-box {
                            width: 45%;
                            display: inline-block;
                            text-align: center !important;
                            vertical-align: top;
                            }
                            .signature-line {
                            border-top: 2px solid black;
                            margin-top: 60px;
                            padding-top: 5px;
                            font-weight: bold;
                            text-align: center !important;
                            }
                            .report-date {
                            margin-top: 30px;
                            text-align: right !important;
                            font-style: italic;
                            }
                            .equal-height-row {
                            display: table;
                            width: 100%;
                            table-layout: fixed;
                            }
                            .equal-height-col {
                            display: table-cell;
                            width: 50%;
                            vertical-align: top;
                            }
                        </style>

                        <div class="header-section">
                            <div class="header-row">
                                <div class="header-col-left">
                                    <img src="/servicio_reparacion/static/src/img/logo1.png" />
                                </div>
                                <div class="header-col-center">
                                    <h2>Informe Técnico Taller</h2>
                                </div>
                                <div class="header-col-right">
                                    <img src="/servicio_reparacion/static/src/img/logo2.png" />
                                </div>
                            </div>
                        </div>

                        <table
                            style="width: 100%; border-collapse: separate; border-spacing: 0; margin-top: 40px; page-break-inside: avoid;">
                            <tr>
                                <!-- Left Column: DATOS GENERALES -->
                                <td
                                    style="width: 49%; vertical-align: top; border: 2px solid #2A3382; padding: 0;">
                                    <div class="section-title-box">1. DATOS GENERALES:</div>
                                    <div style="padding: 10px 15px;">

                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">CLIENTE:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">DIRECCIÓN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.street" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">EMAIL:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.email" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">TELÉFONO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.partner_id.phone" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 100px;">TÉCNICO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.mecanico_id.name" />
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <!-- Spacer Column -->
                                <td
                                    style="width: 2%; border: none !important; background: transparent;"></td>

                                <!-- Right Column: DATOS DEL EQUIPO -->
                                <td
                                    style="width: 49%; vertical-align: top; border: 2px solid #2A3382; padding: 0;">
                                    <div class="section-title-box">2. DATOS DEL EQUIPO:</div>
                                    <div style="padding: 10px 15px;">

                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">MARCA:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.brand_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">VIN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.vin_sn" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">MODELO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.model_id.name" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">PLACA:</div>
                                            <div class="data-value">
                                                <span t-field="doc.vehicle_id.license_plate" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">
                                                KM/ODÓMETRO:</div>
                                            <div class="data-value">
                                                <span t-field="doc.odometer" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">HORAS:</div>
                                            <div class="data-value">
                                                <span t-field="doc.engine_hours" />
                                            </div>
                                        </div>
                                        <div class="data-row">
                                            <div class="data-label" style="width: 120px;">UBICACIÓN:</div>
                                            <div class="data-value">
                                                <span t-field="doc.location" />
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- Section 3: ANTECEDENTES -->
                        <!-- Section 3: ANTECEDENTES -->
                        <table class="section-table">
                            <thead>
                                <tr>
                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <td></td>
                                </tr>
                            </tfoot>
                            <tbody>
                                <tr class="title-row">
                                    <td>3. ANTECEDENTES DEL SERVICIO:</td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <div style="white-space: pre-wrap !important;">
                                            <t t-esc="doc.antecedentes_servicio" />
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Section 4: HALLAZGOS -->
                        <table class="section-table">
                            <thead>
                                <tr>
                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <td></td>
                                </tr>
                            </tfoot>
                            <tbody>
                                <tr class="title-row">
                                    <td>4. HALLAZGOS:</td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <div style="white-space: pre-wrap !important;">
                                            <t t-esc="doc.hallazgos" />
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Section 5: ACCIÓN CORRECTIVA -->
                        <table class="section-table">
                            <thead>
                                <tr>
                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <td></td>
                                </tr>
                            </tfoot>
                            <tbody>
                                <tr class="title-row">
                                    <td>5. ACCIÓN CORRECTIVA:</td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <div style="white-space: pre-wrap !important;">
                                            <t t-esc="doc.accion_correctiva" />
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Section 6: RECOMENDACIONES -->
                        <table class="section-table">
                            <thead>
                                <tr>
                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <td></td>
                                </tr>
                            </tfoot>
                            <tbody>
                                <tr class="title-row">
                                    <td>6. RECOMENDACIONES:</td>
                                </tr>
                                <tr>
                                    <td class="text-start">
                                        <div style="white-space: pre-wrap !important;">
                                            <t t-esc="doc.recomendaciones" />
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div style="height: 20px; width: 100%; clear: both;" />
                        <!-- Section 7: IMÁGENES -->
                        <table class="section-table">
                            <thead>
                                <tr>
                                    <th></th>
                                </tr>
                            </thead>
                            <tfoot>
                                <tr>
                                    <td></td>
                                </tr>
                            </tfoot>
                            <tbody>
                                <tr class="title-row">
                                    <td>7. IMÁGENES:</td>
                                </tr>
                                <tr>
                                    <td style="padding: 15px !important;">
                                        <t t-foreach="doc.image_ids" t-as="img">
                                            <div
                                                style="float: left; width: 50%; padding: 5px; text-align: center; box-sizing: border-box; page-break-inside: avoid;">
                                                <div
                                                    style="border: 2px solid #2A3382; padding: 5px; border-radius: 4px; height: 320px; display: flex; flex-direction: column; justify-content: space-between;">
                                                    <div
                                                        style="flex: 1; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                                                        <img t-if="img.image"
                                                            t-att-src="image_data_uri(img.image)"
                                                            style="max-width: 100%; max-height: 250px; object-fit: contain; margin: 0 auto; display: block;" />
                                                    </div>
                                                    <div t-if="img.description"
                                                        style="margin-top: 8px; color: #333; font-weight: bold; border-top: 1px solid #eee; padding-top: 5px;">
                                                        <span t-field="img.description" />
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                        <div style="clear: both;"></div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- CUSTOM FOOTER -->
                        <div class="report-footer-container" style="padding-top: 40px; width: 100%;">
                            <div class="report-date" style="text-align: right; font-style: italic;">
                                Fecha del Reporte: <span
                                    t-esc="res_company.env.context.get('report_date')"
                                    t-options='{"widget": "date"}' />
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>